project_id = "your-gcp-project-id"
region     = "us-central1"

labels = {
  app         = "cosmos-to-gcp-router"
  environment = "dev"
  stack       = "v2-multiapi-router"
}

create_state_bucket = true
state_bucket_name   = "your-gcp-project-id-cosmos-v2-router-state"

create_firestore_database = true
firestore_database_name   = "(default)"
firestore_location_id     = "us-central"

spanner_instance_name    = "cosmos-v2-router-instance"
spanner_instance_config  = "regional-us-central1"
spanner_processing_units = 100
spanner_database_name    = "cosmos_v2_router_db"

spanner_database_ddl_additional = []

